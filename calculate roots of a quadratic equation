#include<stdio.h>
#include<math.h>
int main()
{
        float a,b,c,D;
        float r1,r2;
        printf("enter the values of a,b,c");
        scanf("%f%f%f",&a,&b,&c);
        D=(b*b)-4*a*c;
        if(D==0)
        {
                r1=-b/(2*a);
                r2=-b/(2*a);
                printf("\nr1:%2f",r1);
                printf("\nr2:%2f",r2);

        }
        else if(D>0)
        {
                r1=b+(sqrt(b*b)-(4*a*c))/2*a;
                r2=b-(sqrt(b*b)-(4*a*c))/2*a;
                printf("\nr1:%2f",r1);
                printf("\nr2:%2f",r2);
        }
        else
        {
                printf("roots are imaginary");

        }
        return 0;
}
