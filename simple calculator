#include<stdio.h>
int main()
{
        int a,b,c;
        int choice;
        printf("1.addition\n");
        printf("2.subtraction\n");
        printf("3.multiplication\n");
        printf("4.division\n");
        printf("5.modulo\n");
        printf("enter the choice");
        scanf("%d",&choice);
        printf("enter two numbers");
        scanf("%d%d",&a,&b);
        switch(choice)
        {
          case 1:
            printf("\naddition result=%d",a+b);
            break;
          case 2:
            printf("\nsubtraction result=%d",a-b);
            break;
          case 3:
            printf("\nmultiplication result=%d",a*b);
            break;
          case 4:
            if(b!=0)
                    printf("%d",a/b);
            else
                    printf("b shows zero division error");
          case 5:
            printf("\nmodulo result=%d",a%b);
            break;
          default:
            printf("\ninvalid choice");
        }
        return 0;
}
